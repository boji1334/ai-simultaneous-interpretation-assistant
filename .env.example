# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ASR provider
ASR_PROVIDER=mock
ASR_MODEL_PATH=./models/faster-whisper-small
ASR_DEVICE=auto
ASR_COMPUTE_TYPE=auto

# Translation provider
TRANSLATION_PROVIDER=mock
TRANSLATION_API_KEY=replace-with-api-key
TRANSLATION_MODEL=replace-with-model-name
TRANSLATION_BASE_URL=https://api.openai.com/v1

# Demo
DEMO_AUDIO_PATH=./assets/demo/demo_en.wav
